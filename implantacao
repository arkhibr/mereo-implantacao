#!/usr/bin/env bash
# Wrapper do CLI de implantação (Linux/macOS).
#
# Usa o python do .venv local quando existir (necessário para os
# subcomandos LLM, já que o openai SDK é instalado lá).
# O carregamento do .env é feito pelo próprio cli.py — funciona igual
# em Linux, macOS e Windows.
set -e

DIR="$(cd "$(dirname "$0")" && pwd)"

if [ -x "$DIR/.venv/bin/python3" ]; then
  exec "$DIR/.venv/bin/python3" "$DIR/cli.py" "$@"
fi

exec python3 "$DIR/cli.py" "$@"
