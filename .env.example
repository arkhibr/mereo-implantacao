# Provider LLM (gateway OpenAI-compatible)
# Default: Abacus RouteLLM com modelo gpt-5.
# Para usar outro provider, ajuste BASE_URL e MODEL conforme a documentação dele.
MEREO_LLM_API_KEY=
MEREO_LLM_BASE_URL=https://routellm.abacus.ai/v1
MEREO_LLM_MODEL=gpt-5

# Limites opcionais (descomente se precisar ajustar)
# MEREO_MAX_TOKENS=16000
# MEREO_MAX_ITERACOES=50
